run/main_scene="uid://gw40albdbm3p"
config/features=PackedStringArray("4.7")
config/icon="res://icon.svg"
run/main_scene.editor="uid://br4m14bakj183"

[audio]

buses/default_bus_layout="uid://c2vm5lodqt500"

[autoload]

PauseSettings="*uid://cnd2s7t71brg0"

[display]

window/size/viewport_width=256
window/size/viewport_height=224
window/size/window_width_override=512
window/size/window_height_override=448
window/stretch/mode="viewport"
window/size/window_width_override.macos=1024
window/size/window_height_override.macos=896

[editor_plugins]

enabled=PackedStringArray("res://addons/script-ide/plugin.cfg", "res://addons/shipitch/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://game/": "blue",
"res://menus/": "green"
}

